<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/itsdata/core/v1/"
     xml:base="https://w3id.org/itsdata/core/v1/"
     xmlns:cc="http://creativecommons.org/ns#"
     xmlns:dcterms="http://purl.org/dc/terms/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:vann="http://purl.org/vocab/vann/"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:cdm1="https://w3id.org/citydata/part1/v1/"
     xmlns:cdm2="https://w3id.org/citydata/part2/v1/"
     xmlns:its-core="https://w3id.org/itsdata/core/v1/">
    <owl:Ontology rdf:about="https://w3id.org/itsdata/core/v1/">
        <!-- Identity -->
		<dcterms:title>ITS Core Ontology</dcterms:title>
    	<skos:definition>This ontology defines core concepts related to intelligent transport systems (ITS).</skos:definition>
    	<vann:preferredNamespaceUri>https://w3id.org/itsdata/itsCore/</vann:preferredNamespaceUri>
		<vann:preferredNamespacePrefix>itsCore</vann:preferredNamespacePrefix>
        <cdm1:mainModule>true</cdm1:mainModule>
        <its-core:draft>true</its-core:draft>
    		
    	<!-- Provenance -->
    	<dcterms:creator>Kenneth Vaughn</dcterms:creator>
		<dcterms:created>Draft</dcterms:created>
        <!-- Prior release -->
        <owl:priorVersion rdf:resource="https://w3id.org/itsdata/itsCore/v1/r0.1"/>
        <!-- This release -->
		<dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-03-03</dcterms:modified>
        <owl:versionInfo>0.0.2</owl:versionInfo>
        <owl:versionIRI rdf:resource="https://w3id.org/itsdata/itsCore/v1/r0.2"/>

        <!-- TODO: I need to make sure that the above IRIs will work, in particular, the w3id redirect needs to be able to recognize that the r#.# extension is a release and not a class or property. -->
        
        <!-- License -->
        <dcterms:license>http://creativecommons.org/licenses/by/4.0/</dcterms:license>
        
        <!-- Imports -->
        <owl:imports rdf:resource="https://w3id.org/citydata/part2/v1/CityPattern/"/>
        <!-- which includes the following cascade of imports:
            LandUsePattern
                CodePattern
                    Core(cdm2)
                    OrganizationStructurePattern
                        AgentPattern
                            GenericPropertiesPattern
                            ResourcePattern
                                ActivityPattern
                                    ChangePattern
                                    SpatialLocPattern
                                        MereologyPattern
                                CityUnitsPattern
                                    ISO21972
                                    Core (cdm1)
                                        Time (W3C)
         -->
    </owl:Ontology>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/core/v1/draft -->

    <owl:AnnotationProperty rdf:about="https://w3id.org/itsdata/core/v1/draft">
    	<skos:definition>Identifies the concept as a draft.</skos:definition>
    </owl:AnnotationProperty>
    
    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    <!-- https://w3id.org/itsdata/core/v1/ITSObjectProperty -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/core/v1/ITSObjectProperty">
    	<skos:definition>An object property to organize all object properties defined in all recognized ITS Ontologies.</skos:definition>
    </owl:ObjectProperty>
    
    <!-- https://w3id.org/itsdata/core/v1/jurisdiction -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/core/v1/jurisdiction">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSObjectProperty"/>
        <skos:definition>The jurisdiction associated with the object.</skos:definition>
        <rdfs:range rdf:resource="https://w3id.org/citydata/part2/v1/JurisdictionalArea"/>
    </owl:ObjectProperty>
    

    <!-- https://w3id.org/itsdata/core/v1/activationStatus -->

    <owl:ObjectProperty rdf:about="https://w3id.org/itsdata/core/v1/activationStatus">
        <skos:definition>The activation status of the object.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSObjectProperty"/>
        <rdfs:range rdf:resource="https://w3id.org/itsdata/core/v1/ActivationStatusCode"/>
    </owl:ObjectProperty>

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/core/v1/ITSDatatypeProperty">
    	<skos:definition>A datatype property to organize all datatype properties defined in all recognized ITS Ontologies.</skos:definition>
    </owl:DatatypeProperty>
    
    <!-- https://w3id.org/itsdata/core/v1/image -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/core/v1/image">
        <skos:definition>The binary content of an image embedded as base64-encoded bytes.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSObjectProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#base64Binary"/>
  </owl:DatatypeProperty>
  

    <!-- https://w3id.org/itsdata/core/v1/url -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/core/v1/url">
        <skos:definition>The URL associated with the object.</skos:definition>
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSObjectProperty"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#anyURI"/>
  </owl:DatatypeProperty>
  

    <!-- https://w3id.org/itsdata/core/v1/version -->

    <owl:DatatypeProperty rdf:about="https://w3id.org/itsdata/core/v1/version">
        <rdfs:subPropertyOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSDataProperty"/>
        <skos:definition>The version of the object.</skos:definition>
    </owl:DatatypeProperty>
    

    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    <owl:Class rdf:about="https://w3id.org/itsdata/core/v1/ITSThing">
    	<skos:definition>A class to organize all classes defined in all recognized ITS Ontologies.</skos:definition>
    </owl:Class>
    
    <!-- https://w3id.org/itsdata/core/v1/ActivationStatusCode -->
    <owl:Class rdf:about="https://w3id.org/itsdata/core/v1/ActivationStatusCode">
        <skos:definition>A code indicating the activation status of an object</skos:definition>
        <skos:example>active, beingSetUp, beingShutDown, inactive, scheduled</skos:example>
        <rdfs:subClassOf rdf:resource="https://w3id.org/itsdata/core/v1/ITSThing"/>
        <rdfs:subClassOf rdf:resource="https://w3id.org/citydata/part2/v1/Code"/>
    </owl:Class>


</rdf:RDF>



