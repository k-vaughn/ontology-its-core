PREFIX sh:          <http://www.w3.org/ns/shacl#>
PREFIX owl:         <http://www.w3.org/2002/07/owl#>
PREFIX rdf:         <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:        <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:         <http://www.w3.org/2001/XMLSchema#>
PREFIX its-sh:      <https://w3id.org/itsdata/core/v1/shacl/>

# =============================================
# Reusable SHACL Shapes Library (Core)
# =============================================

its-sh: a owl:Ontology ;
    rdfs:label "ITS Data Core Reusable SHACL Shapes" ;
    rdfs:comment "Collection of commonly used NodeShapes for cardinality, multilingual strings, and ASN.1 OIDs. Import this file via owl:imports to reuse the shapes." ;
    owl:versionInfo "1.0" .
    
its-sh:ExactlyOneShape a sh:NodeShape ;
    sh:name "exactly 1" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "Exactly one value is required." .

its-sh:MaxOneShape a sh:NodeShape ;
    sh:name "max 1" ;
    sh:maxCount 1 ;
    sh:message "At most one value is allowed." .

its-sh:MinOneShape a sh:NodeShape ;
    sh:name "min 1" ;
    sh:minCount 1 ;
    sh:message "At least one value is required." .

its-sh:UnlimitedShape a sh:NodeShape ;
    sh:name "0..*" ;
    # default 0..* – no minCount / maxCount
    sh:message "Property is optional and may have any number of values." .

its-sh:ExactlyOneMultilingualShape a sh:NodeShape ;
    sh:name "exactly 1 multilingual" ;
    sh:nodeKind sh:Literal ;
    sh:datatype rdf:langString ;
    sh:uniqueLang true ;
    sh:minCount 1 ;
    sh:message "At least one language string is required and only one per language is allowed." .

its-sh:MaxOneMultilingualShape a sh:NodeShape ;
    sh:name "max 1 multilingual" ;
    sh:nodeKind sh:Literal ;
    sh:datatype rdf:langString ;
    sh:uniqueLang true ;
    sh:message "Only one language string per language is allowed for this property." .

its-sh:MinOneMultilingualShape a sh:NodeShape ;
    sh:name "min 1 multilingual" ;
    sh:nodeKind sh:Literal ;
    sh:datatype rdf:langString ;
    sh:minCount 1 ;
    sh:message "At least one language string is required." .

its-sh:OidShape a sh:NodeShape ;
    sh:name "OID" ;
    sh:datatype xsd:string ;    # enforces literal type
    sh:pattern "^(0|1)(\\.(([1-3]{0,1})[0-9]))(\\.(0|[1-9][0-9]*))*|2(\\.(0|[1-9][0-9]*))+$" ;
     # Pattern explanation:
     # - At least two arcs total (e.g., "1.3")
     # - First arc: 0, 1, or 2
     # - If first arc is 0 or 1: second arc 0-39; if first arc is 2: second arc ≥0
     # - Subsequent arcs: non-negative integers with no leading zeros (except single '0')
     # - Allows for large integers in arcs (e.g., "2.999.1234567890")
    sh:message "Value must be a valid ASN.1 OID per ITU-T X.680 / ISO/IEC 8824-1." .

